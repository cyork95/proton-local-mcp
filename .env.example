# ─── Proton Bridge (IMAP) ────────────────────────────────────────────────────
# Open the Proton Bridge app → click your account → copy the credentials shown.
# IMAP host is always 127.0.0.1. Port is shown in Bridge — usually 1143.
# Password = the Bridge-generated password (NOT your Proton login password).

BRIDGE_IMAP_HOST=127.0.0.1
BRIDGE_IMAP_PORT=1143
# Set to true if Bridge uses SSL/TLS (common on Windows).
BRIDGE_IMAP_SECURE=false
BRIDGE_EMAIL=your@proton.me
BRIDGE_PASSWORD=paste_bridge_generated_password_here

# ─── Proton Calendar (ICS share links) ───────────────────────────────────────
# Proton Calendar → gear icon → Share → Create link. Comma-separate multiples.

PROTON_CALENDAR_ICS_URLS=https://calendar.proton.me/api/calendar/v1/url/your_link_here.ics

# ─── Ente Photos (local sync folder) ─────────────────────────────────────────
# Path to your Ente Photos desktop sync folder.

ENTE_PHOTOS_PATH=C:\Users\YourName\Pictures\Ente

# ─── Spotify ──────────────────────────────────────────────────────────────────
# 1. Create a free app at https://developer.spotify.com/dashboard
# 2. In the app settings, add Redirect URI: http://localhost:8888/callback
# 3. Fill in Client ID and Secret below
# 4. Run: node spotify-auth.js  — it opens a browser and prints your refresh token
# 5. Paste the refresh token here

SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REFRESH_TOKEN=paste_after_running_spotify-auth.js

# ─── Proton Drive (local sync folder) ────────────────────────────────────────
# Path to your Proton Drive local sync folder (the "My files" subfolder).

PROTON_DRIVE_PATH=C:\Users\YourName\Proton Drive\YourAccount\My files

# ─── Standard Notes ───────────────────────────────────────────────────────────
# Your Standard Notes login credentials.

STANDARD_NOTES_EMAIL=your@email.com
STANDARD_NOTES_PASSWORD=your_standard_notes_password
STANDARD_NOTES_SERVER=https://api.standardnotes.com
