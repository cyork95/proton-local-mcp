# ─── Google (Gmail, Calendar, Drive, Tasks, Health) ──────────────────────────
# One OAuth credential set covers all Google services.
# 1. https://console.cloud.google.com/ → New Project
# 2. Enable: Gmail API, Google Calendar API, Google Drive API, Tasks API,
#            Google Health API
# 3. OAuth consent screen → add your email as Test User
# 4. Credentials → OAuth 2.0 Client ID → Web app
#    Add redirect URI: http://127.0.0.1:8890/callback
# 5. Run: node --dns-result-order=ipv4first health-auth.js
# 6. Paste the refresh token below

GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REFRESH_TOKEN=paste_after_running_health-auth.js

# ─── Ente Photos (local sync folder) ─────────────────────────────────────────
# Path to your Ente Photos desktop sync folder.

ENTE_PHOTOS_PATH=C:\Users\YourName\Pictures\Ente

# ─── Spotify ──────────────────────────────────────────────────────────────────
# 1. Create a free app at https://developer.spotify.com/dashboard
# 2. In the app settings, add Redirect URI: http://localhost:8888/callback
# 3. Fill in Client ID and Secret below
# 4. Run: node spotify-auth.js  — it opens a browser and prints your refresh token
# 5. Paste the refresh token here

SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REFRESH_TOKEN=paste_after_running_spotify-auth.js

# ─── Standard Notes (local plaintext backup folder) ───────────────────────────
# Path to your Standard Notes automatic plaintext backup folder.
# In the SN desktop app: Preferences → Backups → Plaintext Backups

STANDARD_NOTES_BACKUP_PATH=C:\Users\YourName\Documents\Standard Note Backup\your@email.com\Plaintext Backups
